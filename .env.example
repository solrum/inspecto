# ─── Database ────────────────────────────────────────────────────────────
# In docker-compose, DATABASE_URL is auto-constructed from POSTGRES_* vars.
# Set DATABASE_URL directly only for non-docker deployments.
POSTGRES_USER=inspecto
POSTGRES_PASSWORD=inspecto
POSTGRES_DB=inspecto
DATABASE_URL=postgresql://inspecto:inspecto@localhost:15432/inspecto

# ─── S3 / MinIO (self-hosted) ───────────────────────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=inspecto-files
S3_REGION=us-east-1
S3_PRESIGNED_URL_EXPIRY=900

# ─── Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12
PASSWORD_RESET_EXPIRY_MS=3600000

# ─── API Server ──────────────────────────────────────────────────────────
NODE_ENV=development
API_PORT=3001
CORS_ORIGIN=https://inspecto.solrum.dev

# ─── Upload Limits (bytes) ───────────────────────────────────────────────
MAX_FILE_SIZE=52428800
MAX_IMAGE_SIZE=20971520

# ─── SMTP (self-hosted email) ───────────────────────────────────────────
# Set SMTP_MOCK_MODE=true to log emails to console instead of sending
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASS=
SMTP_REJECT_UNAUTHORIZED=true
SMTP_MOCK_MODE=true
MAIL_FROM=Inspecto <noreply@solrum.dev>
SMTP_FROM_NAME=Inspecto

# ─── App URL (for email links) ──────────────────────────────────────────
APP_URL=https://inspecto.solrum.dev

# ─── Web Client ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://inspecto.solrum.dev/api
